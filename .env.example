# GearGuide-AI Environment Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider API Keys (Priority: 1. Gemini, 2. OpenAI)
# Recommended: Use Google Gemini (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Gemini Model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Application Settings
# LLM Temperature (0.0 = deterministic, higher = more creative)
LLM_TEMPERATURE=0.0

# Maximum tokens for LLM responses
LLM_MAX_TOKENS=4096

# Request timeout in seconds
LLM_TIMEOUT=60

# GearGuide-AI Environment Configuration
# Copy this file to .env and fill in your API keys

# NVIDIA NIM (Priority 1)

NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=mistral-medium-3.5-128b

# Google Gemini (Priority 2 Fallback)

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (Priority 3 Final Fallback)

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini


# Application Settings
# LLM Temperature (0.0 = deterministic, higher = more creative)
LLM_TEMPERATURE=0.0

# Maximum tokens for LLM responses
LLM_MAX_TOKENS=4096

# Request timeout in seconds
LLM_TIMEOUT=60
